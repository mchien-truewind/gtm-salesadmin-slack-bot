# Notion ATS secrets (supports either canonical or alias names)
NOTION_INTERNAL_INTEGRATION_SECRET=
NOTION_DATABASE_ID=
# Aliases used in your current setup:
NOTION_INTERNAL_INTEGRATION=
NOTION_ATS_DB_ID=

# Gmail / Drive / Calendar OAuth paths
GOOGLE_GMAIL_CREDENTIALS_FILE=secrets/google-gmail-credentials.json
GOOGLE_GMAIL_TOKEN_FILE=secrets/google-gmail-token.json
GOOGLE_CALENDAR_CREDENTIALS_FILE=secrets/google-calendar-credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=secrets/google-calendar-token.json
GOOGLE_DRIVE_CREDENTIALS_FILE=secrets/google-drive-credentials.json
GOOGLE_DRIVE_TOKEN_FILE=secrets/google-drive-token.json

# Resume storage folder in Drive
GOOGLE_DRIVE_FOLDER_ID=
# Alias used in your current setup:
GOOGLE_DRIVE_FOLDER_ATS=

# Recruiting workflow config
RECRUITING_GMAIL_LABEL=hiring@
RECRUITING_GMAIL_QUERY=subject:"[hiring@]" has:attachment
RECRUITING_GMAIL_MAX_MESSAGES=50
RECRUITING_HIRING_ALIAS=
RECRUITING_FROM_EMAIL=
RECRUITING_PROCEED_TEMPLATE=Thanks for your submission. When are you free for a 20-minute intro call?
RECRUITING_REJECTION_TEMPLATE=Thank you for your submission. We had an incredibly strong pool of applicants, and after careful consideration, we won't be moving forward with your application at this time. We're growing quickly, though, and new roles open up often. Please keep checking our careers page for future opportunities. We'd be glad to see your application again in the future.
RECRUITING_SCHEDULING_TEMPLATE=Thanks for the quick reply. Are you available for a 20-minute intro call on {slot_label}?
RECRUITING_REJECT_DELAY_HOURS=24
RECRUITING_NO_RESPONSE_WAIT_DAYS=14
RECRUITING_NO_RESPONSE_TEMPLATE=Hi {first_name},\n\nHaven't heard back from you in a while. We're going to close the loop on this process as you figure out your next steps.\n\nWe are growing quickly and we'll be glad to see your application again for another role in the future.\n\nThanks\nMercedes
RECRUITING_ASSIGNMENT_KEYWORDS=assignment,case study,take-home,take home,exercise,project
RECRUITING_SENT_STATUS_LOOKBACK_DAYS=5
RECRUITING_GMAIL_PIPELINE_LABEL=hiring-pipeline
PDL_API=
# Alternative alias:
# PDL_API_KEY=

# Slack hiring review (recommended)
SLACK_BOT_TOKEN=
# Optional fallback:
# SLACK_USER_TOKEN=
RECRUITING_SLACK_REVIEW_CHANNEL=hiring-review
# Optional: set channel ID (for example C0123456789 or G0123456789) to avoid channel-name lookup calls.
RECRUITING_SLACK_REVIEW_CHANNEL_ID=
# Optional: set your Slack member user ID (for example U0123456789) to be @mentioned on each new applicant post.
RECRUITING_SLACK_MENTION_USER_ID=
# Optional fallback alias for mention user id:
# SLACK_USER_ID=
RECRUITING_SLACK_HISTORY_LOOKBACK_DAYS=14
RECRUITING_SLACK_PROCEED_REACTIONS=white_check_mark
RECRUITING_SLACK_REJECT_REACTIONS=x
RECRUITING_SLACK_ALLOW_DECISION_OVERRIDE=false

# Scheduling proposal constraints (draft-only; does not create calendar event)
RECRUITING_SCHEDULING_TIMEZONE=America/Los_Angeles
RECRUITING_SLOT_MINUTES=20
RECRUITING_SCHEDULING_BUFFER_MINUTES=10
RECRUITING_SCHEDULING_MIN_NOTICE_HOURS=24
RECRUITING_SCHEDULING_LOOKAHEAD_DAYS=14
RECRUITING_SCHEDULING_WEEKDAYS=MON,TUE,WED,THU,FRI
RECRUITING_SCHEDULING_START_LOCAL=10:00
RECRUITING_SCHEDULING_END_LOCAL=16:00

# Notion property mapping (change only if your DB uses different names)
RECRUITING_NOTION_PROP_CANDIDATE_NAME=Candidate Name
RECRUITING_NOTION_PROP_EMAIL=Email
RECRUITING_NOTION_PROP_ROLE=Role
RECRUITING_NOTION_PROP_RESUME_URL=Resume URL
RECRUITING_NOTION_PROP_CAREER_STAGE=Career Stage
RECRUITING_NOTION_PROP_LINKEDIN_URL=LinkedIn URL
RECRUITING_NOTION_PROP_LINKEDIN_CONFIDENCE=Confidence Level - LI
RECRUITING_NOTION_PROP_COMPANY=Company
RECRUITING_NOTION_PROP_CURRENT_TITLE=Current Title
RECRUITING_NOTION_PROP_LOCATION=Location
RECRUITING_NOTION_PROP_DATE_FIRST_ENTERED=Date first entered
RECRUITING_NOTION_PROP_DECISION=Decision
RECRUITING_NOTION_PROP_DECISION_TIME=Decision time
RECRUITING_NOTION_PROP_REJECT_SEND_AT=Reject send at
RECRUITING_NOTION_PROP_PROCEED_DRAFT_ID=Proceed draft id
RECRUITING_NOTION_PROP_REJECT_DRAFT_ID=Reject draft id
RECRUITING_NOTION_PROP_GMAIL_THREAD_ID=Gmail thread id
RECRUITING_NOTION_PROP_STATUS=Status
RECRUITING_NOTION_PROP_SCHEDULING_DRAFT_ID=Scheduling draft id
RECRUITING_NOTION_PROP_PROPOSED_SLOT=Proposed Slot
RECRUITING_NOTION_PROP_LAST_SYNC_AT=Last sync at

# Rejection drafts are only auto-sent after this many hours, and only when the
# draft greeting first name matches strong email/resume/LinkedIn evidence and
# an external verifier subagent explicitly approves the send. Missing verifier fails closed.
RECRUITING_REJECT_DRAFT_AUTO_SEND_AGE_HOURS=48
RECRUITING_NAME_VERIFIER_PROVIDER=anthropic
RECRUITING_NAME_VERIFIER_MODEL=claude-3-5-haiku-latest
RECRUITING_ANTHROPIC_API_KEY=
RECRUITING_OPENAI_API_KEY=
