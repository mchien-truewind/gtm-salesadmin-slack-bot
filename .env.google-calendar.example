GOOGLE_CALENDAR_CREDENTIALS_FILE=secrets/google-calendar-credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=secrets/google-calendar-token.json
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=America/Los_Angeles
GOOGLE_CALENDAR_DEFAULT_CALENDAR_ID=primary
GOOGLE_CALENDAR_SEND_UPDATES=all
GOOGLE_WORKSPACE_CREDENTIALS_FILE=secrets/google-calendar-credentials.json
GOOGLE_WORKSPACE_TOKEN_FILE=secrets/google-workspace-token.json
GOOGLE_BRIEF_LOOKAHEAD_HOURS=168
GOOGLE_BRIEF_MAX_ITEMS=5
